<?xml version='1.0' encoding='UTF-8'?>
<project>
    <base_param type="path">../haiti_multiclass_lightweight.xml</base_param>
    <model>
        <name type="str">DMINet</name>
        <compare_model type="str">dminet</compare_model>
        <backbone type="str">compare_native</backbone>
        <base_channels type="int">16</base_channels>
        <compare_adapt_batchnorm type="bool">true</compare_adapt_batchnorm>
        <compare_deep_supervision type="bool">true</compare_deep_supervision>
    </model>
    <logging>
        <run_name type="str">compare_haiti_dminet</run_name>
    </logging>
    <dataset>
        <positive_crop_prob type="float">0.60</positive_crop_prob>
        <rare_crop_prob type="float">0.30</rare_crop_prob>
        <rare_crop_classes type="list">[2, 3]</rare_crop_classes>
        <crop_candidate_count type="int">5</crop_candidate_count>
    </dataset>
    <augmentation>
        <optical_scale_jitter type="float">0.08</optical_scale_jitter>
        <optical_shift_jitter type="float">0.03</optical_shift_jitter>
        <sar_scale_jitter type="float">0.10</sar_scale_jitter>
        <sar_shift_jitter type="float">0.03</sar_shift_jitter>
        <optical_noise_std type="float">0.015</optical_noise_std>
        <sar_noise_std type="float">0.03</sar_noise_std>
    </augmentation>
    <training>
        <batch_size type="int">24</batch_size>
        <gradient_accumulation_steps type="int">1</gradient_accumulation_steps>
        <num_workers type="int">4</num_workers>
        <optimizer type="str">adamw_amsgrad</optimizer>
        <optimizer_betas type="list">[0.9, 0.99]</optimizer_betas>
        <learning_rate type="float">3e-4</learning_rate>
        <weight_decay type="float">7e-4</weight_decay>
        <scheduler type="str">poly_warmup</scheduler>
        <warmup_epochs type="int">4</warmup_epochs>
        <poly_power type="float">0.9</poly_power>
        <min_lr_ratio type="float">0.05</min_lr_ratio>
        <hier_binary_class_weights type="list">[1.0, 3.0]</hier_binary_class_weights>
        <hier_foreground_logit_offset type="float">-0.85</hier_foreground_logit_offset>
        <hier_subclass_weights type="list">[1.2, 1.8, 1.3]</hier_subclass_weights>
        <hier_subclass_label_smoothing type="float">0.05</hier_subclass_label_smoothing>
        <hier_subclass_focal_weight type="float">0.20</hier_subclass_focal_weight>
        <hier_subclass_focal_gamma type="float">2.0</hier_subclass_focal_gamma>
        <hier_foreground_prior_weight type="float">0.20</hier_foreground_prior_weight>
        <sampler_target_classes type="list">[1, 2, 3]</sampler_target_classes>
        <sampler_power type="float">0.6</sampler_power>
        <sampler_max_weight type="float">2.5</sampler_max_weight>
        <best_metric type="str">foreground_hmean_iou</best_metric>
        <early_stop_patience type="int">20</early_stop_patience>
        <early_stop_min_delta type="float">0.001</early_stop_min_delta>
        <aux_loss_weight type="float">0.35</aux_loss_weight>
    </training>
</project>
